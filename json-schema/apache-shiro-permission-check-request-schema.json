{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-shiro/refs/heads/main/json-schema/apache-shiro-permission-check-request-schema.json",
  "title": "PermissionCheckRequest",
  "description": "Permission check request",
  "type": "object",
  "properties": {
    "permission": {
      "type": "string",
      "description": "Shiro permission string (e.g. printer:print, user:edit:123)"
    }
  },
  "required": [
    "permission"
  ]
}