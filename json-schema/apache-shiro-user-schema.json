{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-shiro/refs/heads/main/json-schema/apache-shiro-user-schema.json",
  "title": "User",
  "description": "User account",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "User identifier"
    },
    "username": {
      "type": "string",
      "description": "Username"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Assigned roles"
    },
    "locked": {
      "type": "boolean",
      "description": "Whether the account is locked"
    }
  }
}